@prefix : <http://www.example.org/academic#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

#################################################################
#    Cursos
#################################################################

:Curso_LEI rdf:type :Curso ;
    :designacao "Licenciatura em Engenharia Informática" .

:Curso_LCD rdf:type :Curso ;
    :designacao "Licenciatura em Ciência de Dados" .

#################################################################
#    Anos Letivos
#################################################################

:AnoLetivo_2024_2025 rdf:type :AnoLetivo ;
    :anoLetivoLabel "2024/2025" .

:AnoLetivo_2025_2026 rdf:type :AnoLetivo ;
    :anoLetivoLabel "2025/2026" .

#################################################################
#    Unidades Curriculares
#################################################################

:UC_BD rdf:type :UnidadeCurricular ;
    :codigoUC "BD101" ;
    rdf:type :UnidadeCurricular ;
    :ects 6 ;
    :semestre 1 ;
    :pertenceAoCurso :Curso_LEI ;
    :temNome "Bases de Dados" .

:UC_WS rdf:type :UnidadeCurricular ;
    :codigoUC "WS201" ;
    :ects 6 ;
    :semestre 2 ;
    :pertenceAoCurso :Curso_LEI ;
    :temPreRequisito :UC_BD ;
    :temNome "Web Semântica" .

:UC_POO rdf:type :UnidadeCurricular ;
    :codigoUC "POO101" ;
    :ects 6 ;
    :semestre 1 ;
    :pertenceAoCurso :Curso_LEI ;
    :temNome "Programação Orientada a Objetos" .

:UC_AS rdf:type :UnidadeCurricular ;
    :codigoUC "AS301" ;
    :ects 6 ;
    :semestre 2 ;
    :pertenceAoCurso :Curso_LEI ;
    :temPreRequisito :UC_BD ;
    :temPreRequisito :UC_POO ;
    :temNome "Arquitetura de Sistemas" .

:UC_ML rdf:type :UnidadeCurricular ;
    :codigoUC "ML401" ;
    :ects 6 ;
    :semestre 1 ;
    :pertenceAoCurso :Curso_LCD ;
    :temPreRequisito :UC_BD ;
    :temNome "Machine Learning" .

