@prefix : <http://exemplo.org/academia#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ============================================
# DECLARAÇÃO DA ONTOLOGIA
# ============================================
<http://exemplo.org/academia> a owl:Ontology ;
    rdfs:label "Ontologia de Gestão Académica" ;
    rdfs:comment "Ontologia para representação semântica de entidades académicas: estudantes, docentes, cursos, disciplinas, matrículas e avaliações." .

# ============================================
# CLASSES
# ============================================
:Pessoa a owl:Class ;
    rdfs:label "Pessoa" .

:Estudante a owl:Class ;
    rdfs:subClassOf :Pessoa ;
    rdfs:label "Estudante" .

:EstudanteBolseiro a owl:Class ;
    rdfs:subClassOf :Estudante ;
    rdfs:label "Estudante Bolseiro" .

:Docente a owl:Class ;
    rdfs:subClassOf :Pessoa ;
    rdfs:label "Docente" .

:MembroCorpoDocente a owl:Class ;
    owl:equivalentClass :Docente ;
    rdfs:label "Membro do Corpo Docente" .

:Departamento a owl:Class ;
    rdfs:label "Departamento" .

:Curso a owl:Class ;
    rdfs:label "Curso" .

:Disciplina a owl:Class ;
    rdfs:label "Disciplina" .

:Matricula a owl:Class ;
    rdfs:label "Matrícula" .

:Avaliacao a owl:Class ;
    rdfs:label "Avaliação" .

# ============================================
# RESTRIÇÃO DE CARDINALIDADE (Axioma 5)
# ============================================
:Estudante rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty :estaMatriculadoEm ;
    owl:cardinality 1
] .

# ============================================
# OBJECT PROPERTIES
# ============================================
:estaMatriculadoEm a owl:ObjectProperty ;
    rdfs:domain :Estudante ;
    rdfs:range :Curso ;
    owl:inverseOf :temEstudante ;
    rdfs:label "está matriculado em" .

:temEstudante a owl:ObjectProperty ;
    rdfs:domain :Curso ;
    rdfs:range :Estudante ;
    rdfs:label "tem estudante" .

:frequenta a owl:ObjectProperty ;
    rdfs:domain :Estudante ;
    rdfs:range :Disciplina ;
    owl:inverseOf :temFrequentador ;
    rdfs:label "frequenta" .

:temFrequentador a owl:ObjectProperty ;
    rdfs:domain :Disciplina ;
    rdfs:range :Estudante ;
    rdfs:label "tem frequentador" .

:leciona a owl:ObjectProperty ;
    rdfs:domain :Docente ;
    rdfs:range :Disciplina ;
    owl:inverseOf :leccionadaPor ;
    rdfs:label "leciona" .

:leccionadaPor a owl:ObjectProperty ;
    rdfs:domain :Disciplina ;
    rdfs:range :Docente ;
    rdfs:label "leccionada por" .

:pertenceA a owl:ObjectProperty ;
    rdfs:domain :Disciplina ;
    rdfs:range :Curso ;
    owl:inverseOf :temDisciplina ;
    rdfs:label "pertence a" .

:temDisciplina a owl:ObjectProperty ;
    rdfs:domain :Curso ;
    rdfs:range :Disciplina ;
    rdfs:label "tem disciplina" .

:pertenceDepartamento a owl:ObjectProperty ;
    rdfs:domain :Curso ;
    rdfs:range :Departamento ;
    owl:inverseOf :temCurso ;
    rdfs:label "pertence ao departamento" .

:temCurso a owl:ObjectProperty ;
    rdfs:domain :Departamento ;
    rdfs:range :Curso ;
    rdfs:label "tem curso" .

:trabalhaEm a owl:ObjectProperty ;
    rdfs:domain :Docente ;
    rdfs:range :Departamento ;
    owl:inverseOf :temDocente ;
    rdfs:label "trabalha em" .

:temDocente a owl:ObjectProperty ;
    rdfs:domain :Departamento ;
    rdfs:range :Docente ;
    rdfs:label "tem docente" .

:requerPreRequisito a owl:ObjectProperty, owl:TransitiveProperty ;
    rdfs:domain :Disciplina ;
    rdfs:range :Disciplina ;
    rdfs:label "requer pré-requisito" .

:temAvaliacao a owl:ObjectProperty ;
    rdfs:domain :Estudante ;
    rdfs:range :Avaliacao ;
    owl:inverseOf :avaliacaoDe ;
    rdfs:label "tem avaliação" .

:avaliacaoDe a owl:ObjectProperty ;
    rdfs:domain :Avaliacao ;
    rdfs:range :Estudante ;
    rdfs:label "avaliação de" .

:avaliaDisciplina a owl:ObjectProperty ;
    rdfs:domain :Avaliacao ;
    rdfs:range :Disciplina ;
    rdfs:label "avalia disciplina" .

:colegaDe a owl:ObjectProperty, owl:SymmetricProperty ;
    rdfs:domain :Estudante ;
    rdfs:range :Estudante ;
    rdfs:label "colega de" .

# ============================================
# DATATYPE PROPERTIES
# ============================================
:temNome a owl:DatatypeProperty ;
    rdfs:domain :Pessoa ;
    rdfs:range xsd:string ;
    rdfs:label "tem nome" .

:temEmail a owl:DatatypeProperty ;
    rdfs:domain :Pessoa ;
    rdfs:range xsd:string ;
    rdfs:label "tem email" .

:temNumeroEstudante a owl:DatatypeProperty ;
    rdfs:domain :Estudante ;
    rdfs:range xsd:string ;
    rdfs:label "tem número de estudante" .

:temValorBolsa a owl:DatatypeProperty ;
    rdfs:domain :EstudanteBolseiro ;
    rdfs:range xsd:decimal ;
    rdfs:label "tem valor de bolsa" .

:temCodigo a owl:DatatypeProperty ;
    rdfs:domain :Disciplina ;
    rdfs:range xsd:string ;
    rdfs:label "tem código" .

:temCargaHoraria a owl:DatatypeProperty ;
    rdfs:domain :Disciplina ;
    rdfs:range xsd:integer ;
    rdfs:label "tem carga horária" .

:temNomeCurso a owl:DatatypeProperty ;
    rdfs:domain :Curso ;
    rdfs:range xsd:string ;
    rdfs:label "tem nome de curso" .

:temNota a owl:DatatypeProperty ;
    rdfs:domain :Avaliacao ;
    rdfs:range xsd:decimal ;
    rdfs:label "tem nota" .

:temData a owl:DatatypeProperty ;
    rdfs:domain :Avaliacao ;
    rdfs:range xsd:date ;
    rdfs:label "tem data" .

:temSigla a owl:DatatypeProperty ;
    rdfs:domain :Departamento ;
    rdfs:range xsd:string ;
    rdfs:label "tem sigla" .
