@prefix : <http://exemplo.org/academia#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ============================================
# DEPARTAMENTOS (2)
# ============================================
:DEI a :Departamento ;
    :temSigla "DEI" ;
    rdfs:label "Departamento de Engenharia Informática" .

:DEM a :Departamento ;
    :temSigla "DEM" ;
    rdfs:label "Departamento de Engenharia Mecânica" .

# ============================================
# CURSOS (2)
# ============================================
:CursoInformatica a :Curso ;
    :temNomeCurso "Licenciatura em Ciências da Computação" ;
    :pertenceDepartamento :DEI .

:CursoMecanica a :Curso ;
    :temNomeCurso "Licenciatura em Engenharia Mecânica" ;
    :pertenceDepartamento :DEM .

# ============================================
# DISCIPLINAS (6) - com cadeia de pré-requisitos
# ============================================
:BDI a :Disciplina ;
    :temCodigo "INF101" ;
    :temCargaHoraria 4 ;
    rdfs:label "Bases de Dados I" ;
    :pertenceA :CursoInformatica .

:BDII a :Disciplina ;
    :temCodigo "INF201" ;
    :temCargaHoraria 4 ;
    rdfs:label "Bases de Dados II" ;
    :pertenceA :CursoInformatica ;
    :requerPreRequisito :BDI .

:BDIII a :Disciplina ;
    :temCodigo "INF301" ;
    :temCargaHoraria 4 ;
    rdfs:label "Bases de Dados Avançadas" ;
    :pertenceA :CursoInformatica ;
    :requerPreRequisito :BDII .

:ProgI a :Disciplina ;
    :temCodigo "INF102" ;
    :temCargaHoraria 6 ;
    rdfs:label "Programação I" ;
    :pertenceA :CursoInformatica .

:ProgII a :Disciplina ;
    :temCodigo "INF202" ;
    :temCargaHoraria 6 ;
    rdfs:label "Programação II" ;
    :pertenceA :CursoInformatica ;
    :requerPreRequisito :ProgI .

:IA a :Disciplina ;
    :temCodigo "INF302" ;
    :temCargaHoraria 5 ;
    rdfs:label "Inteligência Artificial" ;
    :pertenceA :CursoInformatica ;
    :requerPreRequisito :ProgII ;
    :requerPreRequisito :BDII .

